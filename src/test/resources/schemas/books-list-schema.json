{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Books list",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "pageCount"],
    "properties": {
      "id": { "type": "integer" },
      "title": { "type": ["string", "null"] },
      "description": { "type": ["string", "null"] },
      "pageCount": { "type": "integer" },
      "excerpt": { "type": ["string", "null"] },
      "publishDate": { "type": ["string", "null"] }
    }
  }
}
