{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Authors list",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id"],
    "properties": {
      "id": { "type": "integer" },
      "idBook": { "type": ["integer", "null"] },
      "firstName": { "type": ["string", "null"] },
      "lastName": { "type": ["string", "null"] }
    }
  }
}
